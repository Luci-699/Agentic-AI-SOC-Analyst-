# =============================================================================
# Environment Configuration — Agentic SOC Analyst
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Wazuh API
# ─────────────────────────────────────────────────────────────────────────────
WAZUH_API_URL=https://localhost:55000
WAZUH_API_USERNAME=wazuh-wui
WAZUH_API_PASSWORD=MyS3cr37P450r.*-
WAZUH_VERIFY_SSL=false

# Wazuh Indexer (OpenSearch)
WAZUH_INDEXER_URL=https://localhost:9200
WAZUH_INDEXER_USERNAME=admin
WAZUH_INDEXER_PASSWORD=SecretPassword

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://soc_user:soc_password@localhost:5432/soc_analyst
DATABASE_URL_SYNC=postgresql://soc_user:soc_password@localhost:5432/soc_analyst

# ─────────────────────────────────────────────────────────────────────────────
# Vector Database (ChromaDB)
# ─────────────────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_INCIDENTS=soc_incidents
CHROMA_COLLECTION_IOCS=soc_iocs

# ─────────────────────────────────────────────────────────────────────────────
# AI Provider — Ollama (Local)
# ─────────────────────────────────────────────────────────────────────────────
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b          # Good balance of speed and reasoning
# OLLAMA_MODEL=mistral:7b          # Alternative
# OLLAMA_MODEL=llama3.1:70b        # If you have a powerful GPU

# ─────────────────────────────────────────────────────────────────────────────
# Alternative: OpenAI (uncomment to switch)
# ─────────────────────────────────────────────────────────────────────────────
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o

# ─────────────────────────────────────────────────────────────────────────────
# Alternative: Anthropic (uncomment to switch)
# ─────────────────────────────────────────────────────────────────────────────
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ─────────────────────────────────────────────────────────────────────────────
# Threat Intelligence APIs (Phase 6) — all have free tiers
# ─────────────────────────────────────────────────────────────────────────────
VIRUSTOTAL_API_KEY=your-vt-api-key          # https://www.virustotal.com/gui/my-apikey
ABUSEIPDB_API_KEY=your-abuseipdb-key       # https://www.abuseipdb.com/account/api
OTX_API_KEY=your-otx-api-key               # https://otx.alienvault.com/api

# ─────────────────────────────────────────────────────────────────────────────
# Application Settings
# ─────────────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-in-production-use-random-64-chars

# Alert collector settings
COLLECTOR_POLL_INTERVAL=30        # seconds between Wazuh API polls
COLLECTOR_BATCH_SIZE=100          # alerts per API call
COLLECTOR_MIN_SEVERITY=3          # only collect alerts level 3+

# Investigation settings
AUTO_INVESTIGATE_MIN_LEVEL=7      # auto-trigger AI for alerts >= level 7
AUTO_INVESTIGATE_GROUPS=brute_force,malware,privilege_escalation

# Response settings
REQUIRE_APPROVAL_FOR=block_ip,disable_user,isolate_endpoint,kill_process
AUTO_APPROVE_FOR=create_ticket,add_watchlist

# ─────────────────────────────────────────────────────────────────────────────
# Notifications (optional)
# ─────────────────────────────────────────────────────────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# SLACK_ALERT_CHANNEL=#soc-alerts
# SLACK_CRITICAL_CHANNEL=#soc-critical

# ─────────────────────────────────────────────────────────────────────────────
# CORS (for React dashboard)
# ─────────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
